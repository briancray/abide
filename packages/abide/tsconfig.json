{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "types": ["bun"],
    "paths": {
      "abide/server/*": ["./src/lib/server/*.ts"],
      "abide/shared/*": ["./src/lib/shared/*.ts"],
      "abide/ui/*": ["./src/lib/ui/*.ts"],
      "abide/bundle/*": ["./src/lib/bundle/*.ts"],
      "abide/test/*": ["./src/lib/test/*.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}

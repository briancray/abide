<script>
import { state } from '@abide/abide/ui/state'

let draft = state('')
let order = state(['1'])
let byId = state({ '1': { text: 'first' } })
let nextId = state(2)

let count = state.computed(() => order.length)

function add() {
    const id = String(nextId)
    byId[id] = { text: draft }
    order.push(id)
    nextId += 1
    draft = ''
}
</script>

<input bind:value={draft} />
<button onclick={add}>Add</button>
<p>Draft: {draft}</p>
<p>Count: {count}</p>

{#if draft}
    <small>typing…</small>
{/if}

<ul>
    {#for id of order by id}
        <li>{byId[id].text}</li>
    {/for}
</ul>

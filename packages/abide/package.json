{
  "name": "abide",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "isomorphic type-safe framework for async interfaces for humans and machines, built on bun and web standards",
  "types": "./ambient.d.ts",
  "exports": {
    ".": { "types": "./ambient.d.ts" },
    "./server/*": "./src/lib/server/*.ts",
    "./shared/*": "./src/lib/shared/*.ts",
    "./ui/*": "./src/lib/ui/*.ts",
    "./bundle/*": "./src/lib/bundle/*.ts",
    "./test/*": "./src/lib/test/*.ts"
  },
  "bin": {
    "abide": "./src/lib/cli/bin.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "bench": "bun run bench/run.ts",
    "bench:delta": "bun run bench/delta.ts"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@types/bun": "latest",
    "bun-plugin-tailwind": "^0.1.2",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.0"
  }
}

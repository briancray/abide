{
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"], "target": "ESNext",
    "module": "Preserve", "moduleResolution": "bundler", "moduleDetection": "force",
    "allowImportingTsExtensions": true, "verbatimModuleSyntax": true, "noEmit": true,
    "strict": true, "skipLibCheck": true, "types": ["bun"]
  },
  "include": ["src/**/*.ts"]
}

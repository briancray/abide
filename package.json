{
    "name": "abide-workspace",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*",
        "examples/*"
    ],
    "scripts": {
        "format": "biome check --write --linter-enabled=false",
        "lint": "biome lint",
        "test": "bun test ./packages/*/tests && for d in examples/*/; do if [ -d \"$d/test\" ]; then (cd \"$d\" && bun test) || exit 1; fi; done",
        "check": "biome check --write",
        "typecheck": "tsgo -p packages/abide/tsconfig.json && tsgo -p packages/abide/tsconfig.consumer.json",
        "check:readme-tags": "bun run packages/abide/scripts/readmeSurfaces.ts",
        "bench": "for f in packages/abide/bench/*.bench.ts; do bun \"$f\"; done",
        "bench:gate": "bun packages/abide/bench/gate.ts",
        "changeset": "changeset",
        "version-packages": "bun run scripts/autofillChangesets.ts && changeset version && bun run scripts/syncRootChangelog.ts",
        "release": "changeset publish"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.16",
        "@changesets/changelog-github": "^0.7.0",
        "@changesets/cli": "^2.29.7",
        "@types/bun": "latest",
        "@typescript/native-preview": "latest",
        "typescript": "^6.0.3"
    }
}

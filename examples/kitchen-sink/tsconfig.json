{
    "extends": "@abide/abide/tsconfig",
    "include": ["src/**/*.ts", "src/.abide/**/*.ts", "src/**/*.abide", "test/**/*.ts"],
    "compilerOptions": {
        "paths": {
            "$server": ["./src/server"],
            "$server/*": ["./src/server/*"],
            "$ui": ["./src/ui"],
            "$ui/*": ["./src/ui/*"],
            "$shared": ["./src/shared"],
            "$shared/*": ["./src/shared/*"],
            "$mcp": ["./src/mcp"],
            "$mcp/*": ["./src/mcp/*"],
            "$cli": ["./src/cli"],
            "$cli/*": ["./src/cli/*"]
        }
    }
}

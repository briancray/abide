<script>
import type { AgentFrame } from '@abide/abide/server/agent'
import { chat } from '$server/rpc/chat.ts'
import CodeBlock from '$ui/CodeBlock.abide'
import Demo from '$ui/Demo.abide'
import TypeDef from '$ui/TypeDef.abide'

// A rendered chat turn: the running transcript the page POSTs and displays.
type ChatMessage = { id: string; role: 'user' | 'assistant'; text: string }
// A tool call surfaced from the stream; `ok` lands later from its tool_result frame.
type ToolCall = { id: string; name: string; input: unknown; ok?: boolean }

import { state } from '@abide/abide/ui/state'
let messages = state<ChatMessage[]>([])
let toolCalls = state<ToolCall[]>([])
let draft = state('Which tools can you call? Use one and show me the result.')
let streaming = state(false)
let error = state<string>()

/* POST the running transcript, then read the JSONL response frame-by-frame,
   folding each AgentFrame into the live assistant turn. */
async function send() {
    const text = draft.trim()
    if (!text || streaming) {
        return
    }
    error = undefined
    toolCalls = []
    const history: ChatMessage[] = [...messages, { id: crypto.randomUUID(), role: 'user', text }]
    draft = ''
    messages = [...history, { id: crypto.randomUUID(), role: 'assistant', text: '' }]
    streaming = true
    try {
        const response = await chat.raw({ messages: history })
        if (!response.ok || !response.body) {
            throw new Error(`HTTP ${response.status}`)
        }
        const reader = response.body.pipeThrough(new TextDecoderStream()).getReader()
        let buffer = ''
        while (true) {
            const { value, done } = await reader.read()
            if (done) {
                break
            }
            buffer += value
            const lines = buffer.split('\n')
            buffer = lines.pop() ?? ''
            for (const line of lines) {
                if (line) {
                    apply(JSON.parse(line))
                }
            }
        }
    } catch (cause) {
        error = cause instanceof Error ? cause.message : String(cause)
    } finally {
        streaming = false
    }
}

/* Fold one frame into the live assistant turn — immutable updates so the doc cell
   re-renders (no nested-mutation reliance). */
function apply(frame: AgentFrame | { $error: string }) {
    if ('$error' in frame) {
        error = frame.$error
        return
    }
    if (frame.type === 'text') {
        const lastIndex = messages.length - 1
        messages = messages.map((message, index) =>
            index === lastIndex && message.role === 'assistant'
                ? { ...message, text: message.text + frame.delta }
                : message,
        )
    } else if (frame.type === 'tool_use') {
        const lastIndex = messages.length - 1
        messages = messages.map((message, index) =>
            index === lastIndex &&
            message.role === 'assistant' &&
            message.text &&
            !message.text.endsWith('\n')
                ? { ...message, text: message.text + '\n\n' }
                : message,
        )
        toolCalls = [...toolCalls, { id: frame.id, name: frame.name, input: frame.input }]
    } else if (frame.type === 'tool_result') {
        toolCalls = toolCalls.map((call) =>
            call.id === frame.id ? { ...call, ok: frame.ok } : call,
        )
    }
}
</script>

<div class="flex flex-col gap-8">
    <div class="flex flex-col gap-2">
        <h1 class="text-3xl font-bold">agent</h1>
        <p class="text-slate-600">
            <code class="font-mono">agent(engine, messages)</code> runs a model against this app's
            own gated MCP surface and streams back <code class="font-mono">AgentFrame</code>s. Here
            the <code class="font-mono">@abide/claude-code</code> engine drives Claude Code over the
            app's schema-bearing rpcs.
        </p>
        <p class="text-xs text-slate-500">
            Permission is fixed server-side: <code class="font-mono">tools: []</code> drops every
            Claude Code built-in and <code class="font-mono">dontAsk</code> denies anything not in
            the <code class="font-mono">allow</code> list, so the agent can only call
            <code class="font-mono">getProduct</code> and <code class="font-mono">getRates</code>.
        </p>
    </div>

    <section class="flex flex-col gap-4">
        <div class="flex flex-col gap-2">
            <h2 class="text-sm font-semibold">Stream API</h2>
            <p class="text-xs text-slate-500">
                The callable you invoke, the message shape you post to it, and each kind of frame it
                streams back — all public types from
                <code class="font-mono">@abide/abide/server/agent</code>, shown in full.
            </p>
        </div>

        <CodeBlock
            title="agent — runs the engine over the app's gated MCP tools, streams AgentFrames"
            code={`function agent(engine: AgentEngine, messages: NeutralMessage[]): AsyncIterable<AgentFrame>`} />

        <TypeDef
            module="@abide/abide/server/agent"
            name="NeutralMessage"
            title="NeutralMessage — the turn shape you post" />

        <TypeDef
            module="@abide/abide/server/agent"
            name="AgentFrame"
            title="AgentFrame — each frame the stream yields" />

        <TypeDef
            module="@abide/abide/server/agent"
            name="AgentEngine"
            title="AgentEngine — the provider adapter you plug in" />
    </section>

    <Demo title="Streaming chat, live" code={`import { agent } from '@abide/abide/server/agent'
import { jsonl } from '@abide/abide/server/jsonl'
import { POST } from '@abide/abide/server/POST'
import { engine } from '@abide/claude-code'

const chatEngine = engine({
    tools: [],
    permissions: {
        defaultMode: 'dontAsk',
        allow: ['mcp__kitchen_sink__getProduct', 'mcp__kitchen_sink__getRates'],
    },
})

export const chat = POST(({ messages }) => jsonl(agent(chatEngine, messages)))`}>
        {#if messages.length > 0}
            <ul class="flex flex-col gap-2">
                {#for message of messages by message.id}
                    <li class="text-sm">
                        <span class={`mr-2 font-mono text-xs uppercase ${message.role === 'user' ? 'text-slate-400' : 'text-indigo-500'}`}>{message.role}</span>
                        <span class="whitespace-pre-wrap text-slate-800">{message.text}</span>
                    </li>
                {/for}
            </ul>
        {/if}
        {#if toolCalls.length > 0}
            <div class="flex flex-col gap-1 rounded-md border border-slate-200 bg-slate-50 p-3">
                <p class="text-xs font-semibold text-slate-500">tool calls</p>
                <ul class="flex flex-col gap-1 font-mono text-xs text-slate-700">
                    {#for call of toolCalls by call.id}
                        <li>
                            <span class={`${call.ok === undefined ? 'text-slate-400' : call.ok ? 'text-emerald-600' : 'text-red-600'}`}>{call.ok === undefined ? '…' : call.ok ? '✓' : '✗'}</span>
                            {call.name} ({JSON.stringify(call.input)})
                        </li>
                    {/for}
                </ul>
            </div>
        {/if}

        <form class="flex gap-2" onsubmit={(event: SubmitEvent) => { event.preventDefault(); void send() }}>
            <input
                type="text"
                bind:value={draft}
                disabled={streaming}
                placeholder="Ask the agent…"
                class="flex-1 rounded-md border border-slate-300 px-3 py-1.5 text-sm outline-none focus:border-slate-500 disabled:opacity-60" />
            <button
                type="submit"
                disabled={streaming}
                class="rounded-md bg-slate-900 px-4 py-1.5 text-sm text-white hover:bg-slate-700 disabled:opacity-60">
                {streaming ? 'streaming…' : 'send'}
            </button>
        </form>

        {#if error}
            <p class="text-sm text-red-600">{error}</p>
        {/if}
    </Demo>
</div>
